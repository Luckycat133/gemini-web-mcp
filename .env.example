# ── Gemini Web Authentication ──────────────────────────────────────────────────
# Get these from https://gemini.google.com (logged in)
# DevTools (F12) → Application → Cookies → Copy values
#
# Required:
GEMINI_PSID="your-__Secure-1PSID-cookie-here"
GEMINI_PSIDTS="your-__Secure-1PSIDTS-cookie-here"

# Optional cookies / extra cookies appended to client requests:
# GEMINI_PSIDCC="your-__Secure-1PSIDCC-cookie-here"

# Optional:
GEMINI_PROXY="http://127.0.0.1:7890"
GEMINI_AUTO_REFRESH=true
GEMINI_TOOLS=core
GEMINI_CHAT_RETENTION_SECONDS=1800

# skill_server local prompt library directory (contains prompts.json):
# GEMINI_CONFIG_DIR=.gemini

# gemini_webapi cookie cache directory; normally managed automatically by
# client_manager when refreshing cookies from a browser:
# GEMINI_COOKIE_PATH=

