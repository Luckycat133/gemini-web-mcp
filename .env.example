# ── Gemini Web Authentication ──────────────────────────────────────────────────
# Get these from https://gemini.google.com (logged in)
# DevTools (F12) → Application → Cookies → Copy values
#
# Required:
GEMINI_SECURE_1PSID="your-__Secure-1PSID-cookie-here"
GEMINI_SECURE_1PSIDTS="your-__Secure-1PSIDTS-cookie-here"

# Optional (but recommended):
GEMINI_SECURE_1PSIDCC="your-__Secure-1PSIDCC-cookie-here"

# ── Rate Limiting ──────────────────────────────────────────────────────────────
# Minimum and maximum random delay between requests (seconds)
REQUEST_DELAY_MIN=1.5
REQUEST_DELAY_MAX=4.0
